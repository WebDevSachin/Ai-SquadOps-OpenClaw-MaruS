# SquadOps Environment Variables
# Copy this to .env and fill in your values

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- OpenRouter ---
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# --- OpenClaw Gateway ---
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxx

# --- Database ---
POSTGRES_PASSWORD=squadops_dev

# --- Auth & Security ---
# JWT secret for token generation (min 32 characters recommended)
JWT_SECRET=change_me_in_production_min_32_chars_long_secret
# Encryption secret for BYOK keys (MUST be exactly 32 characters)
ENCRYPTION_SECRET=12345678901234567890123456789012

# --- OpenCode ---
# Model for coding tasks (default: claude-sonnet-4-5)
OPENCODE_MODEL=anthropic/claude-sonnet-4-5

# --- Optional: Slack ---
# SLACK_BOT_TOKEN=xoxb-xxxxx
# SLACK_SIGNING_SECRET=xxxxx

# --- Optional: S3 Preview Deployment ---
# S3_PREVIEW_BUCKET=squadops-previews
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=xxxxx
# AWS_SECRET_ACCESS_KEY=xxxxx

# --- Optional: Cloudflare Pages ---
# CLOUDFLARE_API_TOKEN=xxxxx
# CLOUDFLARE_ACCOUNT_ID=xxxxx

# --- Optional: System Fallback Provider Keys ---
# These are used if user has no BYOK configured
# SYSTEM_OPENROUTER_KEY=sk-or-xxxxx
# SYSTEM_ANTHROPIC_KEY=sk-ant-xxxxx
