# ============================================================================
# SquadOps API Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================================

# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_VERSION=v1

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql://squadops:squadops_dev@postgres:5432/squadops
DB_HOST=postgres
DB_PORT=5432
DB_NAME=squadops
DB_USER=squadops
DB_PASSWORD=squadops_dev
DB_SSL=false

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# Authentication & Security
# ============================================================================
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_SECRET=your_encryption_secret_32char

CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# External API Keys - LLM Providers
# ============================================================================
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ============================================================================
# System Fallback Provider Keys
# ============================================================================
SYSTEM_OPENROUTER_KEY=
SYSTEM_ANTHROPIC_KEY=
SYSTEM_OPENAI_KEY=

# ============================================================================
# YouTube API (optional)
# ============================================================================
YOUTUBE_API_KEY=
YOUTUBE_API_QUOTA_DAILY=10000

# ============================================================================
# Social Media & Communication
# ============================================================================
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=

# ============================================================================
# Email Configuration (SMTP) (optional)
# ============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@squadops.ai

# ============================================================================
# File Storage (S3/MinIO) (optional)
# ============================================================================
S3_ENDPOINT=s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=squadops-data
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_USE_SSL=true

# ============================================================================
# Preview Deployment
# ============================================================================
PREVIEW_DEPLOY_TARGET=local
PREVIEW_BASE_URL=http://localhost:3001/previews

# ============================================================================
# Cloudflare Pages (optional)
# ============================================================================
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ============================================================================
# Vercel (optional)
# ============================================================================
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# ============================================================================
# Monitoring & Logging
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=combined
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_SWARM_SYSTEM=true
ENABLE_YOUTUBE_RESEARCH=true
ENABLE_REAL_TIME_EVENTS=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SLACK_NOTIFICATIONS=false

# ============================================================================
# Internal Services
# ============================================================================
WORKER_SERVICE_URL=http://localhost:3002
WS_SERVER_URL=ws://localhost:3003
INTERNAL_API_KEY=internal-service-key-change-me

# ============================================================================
# Debug
# ============================================================================
DEBUG=false
AUTO_MIGRATE=false
AUTO_SEED=false
