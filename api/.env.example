# ============================================================================
# SquadOps API Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================================

# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
# Option 1: Full connection string
# DATABASE_URL=postgresql://username:password@localhost:5432/squadops

# Option 2: Individual connection parameters
DB_HOST=localhost
DB_PORT=5432
DB_NAME=squadops
DB_USER=squadops
DB_PASSWORD=squadops_dev
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================================================
# Redis Configuration (for caching, sessions, and real-time features)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# Authentication & Security
# ============================================================================
# JWT secret for token generation (min 32 characters, generate with: openssl rand -hex 32)
JWT_SECRET=change_me_in_production_min_32_chars_long_secret_key_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Encryption secret for BYOK keys (MUST be exactly 32 characters for AES-256)
ENCRYPTION_SECRET=12345678901234567890123456789012

# CORS settings
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# External API Keys - LLM Providers
# ============================================================================
# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenRouter (access to multiple models)
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# OpenAI (GPT models)
OPENAI_API_KEY=sk-openai-xxxxx

# Google AI (Gemini)
GOOGLE_AI_API_KEY=AIzaXXXXX

# ============================================================================
# YouTube API Configuration
# ============================================================================
YOUTUBE_API_KEY=AIzaSyXXXXX
YOUTUBE_API_QUOTA_DAILY=10000

# ============================================================================
# Social Media & Communication
# ============================================================================
# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxx

# Slack (optional)
SLACK_BOT_TOKEN=xoxb-xxxxx
SLACK_SIGNING_SECRET=xxxxx
SLACK_WEBHOOK_URL=

# Discord (optional)
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=

# ============================================================================
# Email Configuration (SMTP)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@squadops.ai
SMTP_SECURE=false

# ============================================================================
# File Storage (S3/MinIO)
# ============================================================================
# S3 Configuration
S3_ENDPOINT=s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=squadops-data
S3_ACCESS_KEY_ID=xxxxx
S3_SECRET_ACCESS_KEY=xxxxx
S3_USE_SSL=true

# MinIO Configuration (alternative to S3)
# S3_ENDPOINT=localhost:9000
# S3_USE_SSL=false
# S3_PATH_STYLE=true

# ============================================================================
# Deployment & Preview Settings
# ============================================================================
# Preview deployment target: local, s3, cloudflare, vercel
PREVIEW_DEPLOY_TARGET=local
PREVIEW_BASE_URL=http://localhost:3001/previews

# Cloudflare Pages (optional)
CLOUDFLARE_API_TOKEN=xxxxx
CLOUDFLARE_ACCOUNT_ID=xxxxx

# Vercel (optional)
VERCEL_TOKEN=xxxxx
VERCEL_TEAM_ID=

# ============================================================================
# Monitoring & Logging
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=combined

# Sentry (error tracking - optional)
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
SENTRY_ENVIRONMENT=development

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_SWARM_SYSTEM=true
ENABLE_YOUTUBE_RESEARCH=true
ENABLE_REAL_TIME_EVENTS=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SLACK_NOTIFICATIONS=false

# ============================================================================
# Development Settings
# ============================================================================
# Enable debug logging
DEBUG=false

# Auto-migrate database on startup (development only)
AUTO_MIGRATE=false

# Seed database on startup (development only)
AUTO_SEED=false

# ============================================================================
# System Fallback Provider Keys (for when users have no BYOK configured)
# WARNING: Use sparingly to control costs - encourage BYOK in production
# ============================================================================
# SYSTEM_OPENROUTER_KEY=sk-or-xxxxx
# SYSTEM_ANTHROPIC_KEY=sk-ant-xxxxx
# SYSTEM_OPENAI_KEY=sk-openai-xxxxx

# ============================================================================
# Internal Services (for microservices architecture)
# ============================================================================
# Worker service URL
WORKER_SERVICE_URL=http://localhost:3002

# WebSocket server URL
WS_SERVER_URL=ws://localhost:3003

# Internal API key for service-to-service communication
INTERNAL_API_KEY=internal-service-key-change-me
