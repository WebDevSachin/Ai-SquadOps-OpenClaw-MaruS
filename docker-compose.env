# ============================================================================
# SquadOps Docker Environment Configuration
# Use with: docker-compose --env-file docker-compose.env up
# ============================================================================

# ----------------------------------------------------------------------------
# Node Environment
# ----------------------------------------------------------------------------
NODE_ENV=development

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
POSTGRES_USER=squadops
POSTGRES_PASSWORD=squadops_dev
POSTGRES_DB=squadops

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
REDIS_PASSWORD=

# ----------------------------------------------------------------------------
# JWT & Encryption (generate with: openssl rand -hex 32)
# ----------------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
ENCRYPTION_SECRET=your_encryption_secret_32char

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# ----------------------------------------------------------------------------
# Frontend URL
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://api:4000
FRONTEND_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# LLM Providers
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# System Fallback Keys
SYSTEM_OPENROUTER_KEY=
SYSTEM_ANTHROPIC_KEY=

# ----------------------------------------------------------------------------
# OpenClaw Gateway
# ----------------------------------------------------------------------------
OPENCLAW_GATEWAY_TOKEN=your_gateway_token

# ----------------------------------------------------------------------------
# Telegram Bot (optional)
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
ENABLE_SWARM_SYSTEM=true
ENABLE_YOUTUBE_RESEARCH=true
