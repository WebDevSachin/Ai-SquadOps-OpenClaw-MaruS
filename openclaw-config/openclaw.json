  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "channels": {
    "whatsapp": {
      "sendReadReceipts": true,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "textChunkLimit": 4000,
      "mediaMaxMb": 50,
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "debounceMs": 0
    },
    "telegram": {
      "dmPolicy": "pairing",
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "groupPolicy": "allowlist",
      "streamMode": "partial"
    },
    "discord": {
      "groupPolicy": "allowlist",
      "dm": {
        "enabled": true,
        "policy": "pairing"
      },
      "guilds": {}
    },
    "googlechat": {
      "groupPolicy": "allowlist"
    },
    "slack": {
      "mode": "socket",
      "webhookPath": "/slack/events",
      "userTokenReadOnly": true,
      "groupPolicy": "allowlist",
      "slashCommand": {
        "enabled": true,
        "name": "openclaw"
      },
      "dm": {
        "enabled": true,
        "policy": "pairing"
      },
      "channels": {}
    },
    "signal": {
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist"
    },
    "imessage": {
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist"
    },
    "msteams": {
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist"
    }
  },
