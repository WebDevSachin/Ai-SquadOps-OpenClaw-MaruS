        }
      },
      {
        "id": "clerk",
        "name": "Clerk",
        "workspace": "/home/node/.openclaw/workspace-clerk",
        "model": "kimi/moonshot-v1-32k",
        "tools": {
          "allow": ["read", "write", "edit", "sessions_send"],
          "deny": ["exec", "browser", "canvas", "cron"]
        }
      }
    ]
  },
  "bindings": [
    { "agentId": "marus", "match": { "channel": "telegram" } },
    { "agentId": "marus", "match": { "channel": "slack" } },
    { "agentId": "marus", "match": { "channel": "cli" } }
  ],
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": [
        "marus", "forge", "canvas", "helm", "aegis", "vault", "architect", "patcher",
        "scout", "scribe", "sentinel", "lens", "herald", "oracle", "guide", "beacon",
        "shield", "compass", "warden", "prism", "clerk"
      ]
    }
  },
  "channels": {
    "telegram": {
      "enabled": true
    },
    "slack": {
      "enabled": false
    }
  },
  "gateway": {
    "port": 18789,
    "bind": "lan"
  },
  "models": {
    "providers": {
      "kimi": {
        "apiKey": "${KIMI_API_KEY}",
        "baseURL": "${KIMI_API_BASE}",
        "type": "openai"
      }
    },
    "aliases": {
      "default": "kimi/moonshot-v1-128k",
      "fast": "kimi/moonshot-v1-32k"
    }
  },
  "skills": {
    "load": {
      "extraDirs": ["./skills"],
      "watch": true,
      "watchDebounceMs": 250
    },
    "entries": {
      "opencode-controller": { "enabled": true },
      "preview-deploy": { "enabled": true },
      "safety-scanner": { "enabled": true }
    }
  }
}
