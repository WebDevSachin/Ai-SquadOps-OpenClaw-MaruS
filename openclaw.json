{
  "agents": {
    "defaults": {
      "sandbox": {
        "mode": "non-main",
        "scope": "agent",
        "workspaceAccess": "rw",
        "docker": {
          "image": "openclaw-sandbox:bookworm-slim",
          "readOnlyRoot": true,
          "tmpfs": ["/tmp", "/var/tmp"],
          "network": "none",
          "user": "1000:1000",
          "capDrop": ["ALL"],
          "pidsLimit": 256,
          "memory": "1g",
          "memorySwap": "2g",
          "cpus": 1,
          "setupCommand": "apt-get update && apt-get install -y git curl jq"
        },
        "prune": {
          "idleHours": 24,
          "maxAgeDays": 7
        }
      }
    },
    "list": [
      {
        "id": "marus",
        "name": "MaruS",
        "default": true,
        "workspace": "/home/node/.openclaw/workspace-marus",
        "model": "kimi/moonshot-v1-128k",
        "sandbox": { "mode": "off" }
      },
      {
        "id": "forge",
        "name": "Forge",
        "workspace": "/home/node/.openclaw/workspace-forge",
        "model": "kimi/moonshot-v1-128k",
        "sandbox": {
          "docker": {
            "network": "bridge",
            "setupCommand": "apt-get update && apt-get install -y git curl jq python3 build-essential && npm install -g opencode@latest"
          }
        },
        "tools": {
          "allow": ["exec", "read", "write", "edit", "apply_patch", "sessions_send", "sessions_spawn"],
          "deny": ["browser", "canvas", "cron"]
        }
      },
      {
        "id": "canvas",
        "name": "Canvas",
        "workspace": "/home/node/.openclaw/workspace-canvas",
        "model": "kimi/moonshot-v1-128k",
        "sandbox": {
          "docker": {
            "network": "bridge",
            "setupCommand": "apt-get update && apt-get install -y git curl jq && npm install -g opencode@latest"
          }
        },
        "tools": {
          "allow": ["exec", "read", "write", "edit", "apply_patch", "sessions_send", "browser"],
          "deny": ["cron"]
        }
      },
      {
        "id": "helm",
        "name": "Helm",
        "workspace": "/home/node/.openclaw/workspace-helm",
        "model": "kimi/moonshot-v1-128k",
        "sandbox": {
          "docker": {
            "network": "bridge",
            "setupCommand": "apt-get update && apt-get install -y git curl jq docker.io && npm install -g opencode@latest"
          }
        },
        "tools": {
          "allow": ["exec", "read", "write", "edit", "apply_patch", "sessions_send"],
          "deny": ["browser", "canvas"]
        }
      },
      {
        "id": "aegis",
        "name": "Aegis",
        "workspace": "/home/node/.openclaw/workspace-aegis",
        "model": "kimi/moonshot-v1-32k",
        "sandbox": {
          "docker": {
            "network": "bridge",
